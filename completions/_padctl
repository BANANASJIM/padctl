#compdef padctl
# Generated by scripts/generate-shell-completions.py.

local -a padctl_commands
padctl_commands=(
  'install:install padctl and its system integration'
  'uninstall:remove installed padctl files'
  'scan:list connected HID devices and config matches'
  'list-mappings:list discovered mapping profiles'
  'reload:reload device configs'
  'switch:switch or re-apply a mapping'
  'output-profile:list or persist a device output profile'
  'status:show daemon status'
  'devices:list connected devices through the daemon'
  'doctor:print a self-contained diagnostic'
  'dump:manage diagnostic logging'
  'config:manage device and mapping configs'
)

_padctl_mapping_names() {
  local -a mappings local_mappings
  mappings=("${(@f)$(command padctl list-mappings --names 2>/dev/null)}")
  local_mappings=(mappings/*.toml(N:t:r))
  mappings+=("${local_mappings[@]}")
  (( ${#mappings} )) && _describe 'mapping name' mappings
}

_padctl_mapping_or_file() {
  _alternative \
    'mappings:mapping name:_padctl_mapping_names' \
    'files:mapping file:_files'
}

_padctl_install() {
  _arguments \
    '--prefix[installation prefix]:directory:_directories' \
    '--destdir[package staging root]:directory:_directories' \
    '--immutable[use immutable OS placement]' \
    '--no-immutable[force standard placement]' \
    '*--mapping[mapping profile name]:mapping name:_padctl_mapping_names' \
    '--force-mapping[overwrite existing mapping files]' \
    '--force-binding[overwrite device bindings]' \
    '--user-service[force user-scope service installation]' \
    '--no-user-service[skip user service enable and start]' \
    '--no-enable[skip systemctl enable]' \
    '--no-start[skip systemctl start]' \
    '--scope[installation scope]:scope:(system user package)' \
    '(-h --help)'{-h,--help}'[show help]'
}
_padctl_uninstall() {
  _arguments \
    '--prefix[installation prefix]:directory:_directories' \
    '--destdir[package staging root]:directory:_directories' \
    '--immutable[also remove immutable-specific files]' \
    '--no-immutable[force standard placement]' \
    '*--mapping[mapping profile name]:mapping name:_padctl_mapping_names' \
