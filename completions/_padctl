_padctl_output_profile() {
  local context state line
  local -a subcommands
  subcommands=(
    'list:show the final backend, protocol, and stick range'
    'select:select an exact profile for a device'
    'reset:clear the per-device selection'
  )
  _arguments -C \
    '1:subcommand:->subcommand' \
    '*::argument:->arguments' \
    '(-h --help)'{-h,--help}'[show help]'
  case $state in
    subcommand) _describe 'output-profile subcommand' subcommands ;;
    arguments)
      case $line[1] in
        list) _padctl_output_profile_list ;;
        select) _padctl_output_profile_select ;;
        reset) _padctl_output_profile_reset ;;
      esac
      ;;
  esac
}
