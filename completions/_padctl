_padctl() {
  local context state line
  _arguments -C \
    '--config[device config TOML]:file:_files' \
    '--config-dir[discover device configs in a directory]:directory:_directories' \
    '--mapping[mapping config TOML]:mapping name or file:_padctl_mapping_or_file' \
    '*--validate[validate a config and exit]:file:_files' \
    '--pid-file[write the daemon PID]:file:_files' \
    '--doc-gen[generate Markdown device reference]' \
    '--output[documentation output directory]:directory:_directories' \
    '(-h --help)'{-h,--help}'[show help]' \
    '(-V --version)'{-V,--version}'[show version]' \
    '1:command:->command' \
    '*::argument:->arguments'

  case $state in
    command)
      _describe 'padctl command' padctl_commands
      ;;
    arguments)
      case $line[1] in
        install) _padctl_install ;;
        uninstall) _padctl_uninstall ;;
        scan) _padctl_scan ;;
        list-mappings) _padctl_list_mappings ;;
        reload) _padctl_reload ;;
        switch) _padctl_switch ;;
        output-profile) _padctl_output_profile ;;
        status) _padctl_status ;;
        devices) _padctl_devices ;;
        doctor) _padctl_doctor ;;
        dump) _padctl_dump ;;
        config) _padctl_config ;;
      esac
      ;;
  esac
}

_padctl "$@"
